-- Triggers immediately when the entity spawns in the map
Entity:SetCallback("OnSpawned", function()
    print("[Rippah Spawner] " .. MyCustomEntityConfig.Entity.Name .. " has successfully entered the hotel!")
    -- Place custom spawn audio, screen flashes, or global system announcements here:
    -- local spawnSound = Instance.new("Sound", workspace) ...
end)
-- Triggers when the entity finishes its delay countdown and starts rushing through rooms
Entity:SetCallback("OnStartMoving", function()
    print("[Rippah Spawner] " .. MyCustomEntityConfig.Entity.Name .. " has begun its run!")
end)
-- Triggers every time the entity enters a new room
Entity:SetCallback("OnEnterRoom", function(roomModel, isFirstTime)
    local roomNumber = roomModel.Name
    print("[Rippah Spawner] Entity entered Room " .. tostring(roomNumber) .. " (First time: " .. tostring(isFirstTime) .. ")")
end)
-- Triggers every time the entity touches a path node
Entity:SetCallback("OnReachNode", function(node)
    -- Highly optimized for custom node actions (e.g., tracking current position)
end)
-- Triggers whenever the player is looking directly at the entity
Entity:SetCallback("OnLookAt", function(inSight)
    -- Can be used to trigger custom static effects or hallucination scripts on the screen
end)
-- Triggers when the entity begins a rebound lap
Entity:SetCallback("OnRebounding", function(isStartingRebound)
    if isStartingRebound then
        print("[Rippah Spawner] Warning: Entity is returning!")
    else
        print("[Rippah Spawner] Entity finished rebound loop.")
    end
end)
-- Triggers when the entity damages a player
Entity:SetCallback("OnDamagePlayer", function(remainingHealth)
    print("[Rippah Spawner] Player damaged! Remaining Health: " .. tostring(remainingHealth))
end)
-- Triggers right before the entity is deleted from workspace
Entity:SetCallback("OnDespawning", function()
    print("[Rippah Spawner] Entity has reached the final room. Despawning...")
end)
-- Triggers when the entity is completely cleaned up
Entity:SetCallback("OnDespawned", function()
    print("[Rippah Spawner] Clean up complete.")
end)
