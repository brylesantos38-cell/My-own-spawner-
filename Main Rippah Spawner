if not RippahSpawner then
    local success, result = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/brylesantos38-cell/My-own-spawner-/refs/heads/main/Function's"))()
    end)
    if not success or not getgenv().RippahSpawner then
        error("[Rippah Spawner - Main] Failed to initialize the spawner core module. Details: " .. tostring(result))
    end
    RippahSpawner = getgenv().RippahSpawner
end
