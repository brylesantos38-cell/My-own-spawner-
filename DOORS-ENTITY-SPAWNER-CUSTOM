-- \\ Helper Functions // --
local function CloneTable<T>(tbl: T): T
    if type(tbl) ~= "table" then return tbl end
    local copy = {}
    for k, v in pairs(tbl :: any) do
        copy[k] = (type(v) == "table") and CloneTable(v) or v
    end
    return copy :: any
end

local function ApplyConfigDefaults(tbl: {}, defaults: {}): {}
    local new = CloneTable(tbl)
    for key, value in pairs(defaults) do
        if new[key] == nil then
            new[key] = (type(value) == "table") and CloneTable(value) or value
        elseif type(value) == "table" then
            if type(new[key]) ~= "table" then
                new[key] = {}
            end
            new[key] = ApplyConfigDefaults(new[key], value)
        end
    end
    return new
end

-- Generates or resolves the entity base model (handling 3D vs 2D automatically)
local function ResolveEntityModel(config: any): Model?
	local entConfig = config.Entity
	if entConfig.Is2D then
		local model = Instance.new("Model")
		model.Name = entConfig.Name or "2D_Entity"

		local root = Instance.new("Part")
		root.Name = "Root"
		root.Size = entConfig.ImageSize or Vector3.new(5, 5, 0.2)
		root.Transparency = 1
		root.CanCollide = false
		root.Anchored = true
		root.Parent = model
		model.PrimaryPart = root

		local formattedId = tostring(entConfig.ImageId)
		if not string.match(formattedId, "://") then
			formattedId = "rbxassetid://" .. formattedId
		end

		-- Create standard front decal
		local frontDecal = Instance.new("Decal")
		frontDecal.Name = "FrontDecal"
		frontDecal.Face = Enum.NormalId.Front
		frontDecal.Texture = formattedId
		frontDecal.Parent = root

		-- Create standard back decal so it is visible from behind
		local backDecal = Instance.new("Decal")
		backDecal.Name = "BackDecal"
		backDecal.Face = Enum.NormalId.Back
		backDecal.Texture = formattedId
		backDecal.Parent = root

		return model
	else
		return LoadCustomInstance(entConfig.Asset)
	end
end

